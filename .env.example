# Catalog directory (default ./catalog). Relative resolves against the working
# directory; absolute is used as-is. The `mock-server <catalogPath>` CLI arg overrides it.
# CATALOG_PATH=./catalog
# MongoDB for mock profiles, global mock selections, and profile key mappings
MONGODB_CONNECTION_STRING=mongodb://localhost:27017
MONGODB_DB=mockDB
# false (default): default.json is selected by default; "real" is offered last.
# true: "real" is selected by default and startup requires every system's baseUrlEnv.
PASSTHROUGH_AS_DEFAULT=false
# ERROR (default): a request from an unknown profile is a loud 404.
# DEFAULT_MOCK: serve the endpoint's "default" scenario for an unknown profile.
# REAL: proxy an unknown profile's request to the real upstream.
UNMOCKED_USERS=ERROR
# How many previously-returned scenario slugs are kept per resolver-backed scenario
# (<scenario>.mjs) and passed to it as `history`. Positive integer.
RESOLVER_HISTORY_LIMIT=10
# How long a resolver history window survives for a caller with no profile (an ID seen
# under UNMOCKED_USERS=DEFAULT_MOCK); the clock restarts on each call from that ID.
# History owned by a real profile or a global mock never expires. Units s|m|h|d.
RESOLVER_HISTORY_TTL_DURATION=1d
# Console request logging threshold: info logs every mock request; warn logs only
# warnings/errors; error logs only framework/routing/setup failures.
MOCK_CONSOLE_LOG_LEVEL=info
# Real upstreams — one env var per system's baseUrlEnv (see catalog/<system>/_system.json).
# Required at startup when PASSTHROUGH_AS_DEFAULT=true; otherwise required only when a
# request resolves to "real".
HELLO_SYSTEM_URL=http://localhost:9999
PASSTHROUGH_TIMEOUT_MS=30000
