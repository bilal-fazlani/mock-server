{
  "name": "mock-server",
  "version": "0.1.0",
  "bin": {
    "mock-server": "bin/mock-server.js"
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    ".next/standalone",
    "bin"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "validate:catalog": "tsx scripts/validate-catalog.ts",
    "prepack": "npm run build && cp -r .next/static .next/standalone/.next/static && cp -r public .next/standalone/public && node scripts/prepack-standalone.mjs"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "esbuild": "^0.25.12",
    "lucide-react": "^1.23.0",
    "mongodb": "^7.4.0",
    "mongodb-memory-server": "^11.2.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tsx": "^4.22.5",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
