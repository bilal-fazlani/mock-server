{
  "name": "@bilal-fazlani/mock-server",
  "version": "0.3.0",
  "description": "A generic, catalog-driven HTTP API mock server — run via npx or Docker, no request-handling code required.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bilal-fazlani/mock-server.git"
  },
  "homepage": "https://github.com/bilal-fazlani/mock-server#readme",
  "keywords": [
    "mock",
    "mock-server",
    "api",
    "testing",
    "http"
  ],
  "bin": {
    "mock-server": "bin/mock-server.js"
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    ".next/standalone",
    "bin"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "validate:catalog": "tsx scripts/validate-catalog.ts",
    "prepack": "npm run build && cp -r .next/static .next/standalone/.next/static && cp -r public .next/standalone/public && node scripts/prepack-standalone.mjs"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "esbuild": "^0.25.12",
    "lucide-react": "^1.23.0",
    "mongodb": "^7.4.0",
    "mongodb-memory-server": "^11.2.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.19",
    "radix-ui": "^1.6.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shiki": "^4.3.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tsx": "^4.22.5",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
